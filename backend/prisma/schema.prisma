// ============================================================
// NexusCRM Enterprise Schema
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES_REP
  SUPPORT
  USER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  DISQUALIFIED
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  EMAIL_CAMPAIGN
  COLD_CALL
  TRADE_SHOW
  PAID_AD
  ORGANIC_SEARCH
  PARTNER
  OTHER
}

enum DealStage {
  PROSPECTING
  QUALIFICATION
  NEEDS_ANALYSIS
  VALUE_PROPOSITION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CommunicationChannel {
  EMAIL
  PHONE
  WHATSAPP
  SMS
  MEETING
  NOTE
}

enum AutomationTrigger {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  DEAL_STAGE_CHANGED
  DEAL_CREATED
  TASK_OVERDUE
  TICKET_CREATED
  CONTACT_CREATED
  SCHEDULED
}

enum AutomationAction {
  SEND_EMAIL
  CREATE_TASK
  ASSIGN_TO_USER
  UPDATE_FIELD
  SEND_WEBHOOK
  SEND_SMS
  CREATE_NOTIFICATION
}

enum NotificationType {
  TASK_DUE
  LEAD_ASSIGNED
  DEAL_WON
  DEAL_LOST
  TICKET_ASSIGNED
  MENTION
  SYSTEM
  AUTOMATION
}

enum DocumentType {
  CONTRACT
  INVOICE
  PROPOSAL
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ============================================================
// USERS & ROLES
// ============================================================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  password     String
  role         Role      @default(USER)
  avatar       String?
  phone        String?
  timezone     String    @default("Asia/Kolkata")
  language     String    @default("en")
  isActive     Boolean   @default(true)
  isVerified   Boolean   @default(false)
  lastLoginAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  preference        Preference?
  refreshTokens     RefreshToken[]
  activityLogs      ActivityLog[]
  notifications     Notification[]

  // Team
  teamId        String?
  team          Team?           @relation("TeamMembers", fields: [teamId], references: [id])
  managedTeams  Team[]          @relation("TeamManager")
  managerId     String?
  manager       User?           @relation("UserManager", fields: [managerId], references: [id])
  directReports User[]          @relation("UserManager")

  // Custom role permissions
  customPermissions Json?        // override permissions for this user

  // CRM ownership
  ownedLeads        Lead[]       @relation("LeadOwner")
  assignedLeads     Lead[]       @relation("LeadAssignee")
  ownedContacts     Contact[]
  ownedDeals        Deal[]       @relation("DealOwner")
  assignedDeals     Deal[]       @relation("DealAssignee")
  tasks             Task[]       @relation("TaskOwner")
  assignedTasks     Task[]       @relation("TaskAssignee")
  tickets           SupportTicket[]
  assignedTickets   SupportTicket[] @relation("TicketAssignee")
  communications    Communication[]
  documents         Document[]
  invoices          Invoice[]
  automationLogs    AutomationLog[]
  // Enterprise v2
  preferredLanguage   String?      @default("en")
  quotes              Quote[]      @relation("UserQuotes")
  purchaseOrders      PurchaseOrder[] @relation("UserPOs")
  pipelineTransitions PipelineDealTransition[] @relation("UserPipelineTransitions")
  projects            Project[]               @relation("UserProjects")
  projectMembers      ProjectMember[]         @relation("UserProjectMembers")
  projectTasks        ProjectTask[]           @relation("UserProjectTasks")

  @@index([email])
  @@index([role])
  @@index([teamId])
  @@index([deletedAt])
}

model Team {
  id          String   @id @default(uuid())
  name        String
  description String?
  managerId   String
  manager     User     @relation("TeamManager", fields: [managerId], references: [id])
  members     User[]   @relation("TeamMembers")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([managerId])
}

model RolePermission {
  id         String   @id @default(uuid())
  role       Role
  resource   String   // e.g. "leads", "deals", "contacts"
  action     String   // e.g. "create", "read", "update", "delete"
  allowed    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([role, resource, action])
  @@index([role])
}

model Preference {
  id               String   @id @default(uuid())
  theme            String   @default("dark")
  accentColor      String   @default("violet")
  sidebarCollapsed Boolean  @default(false)
  selectedModules  Json     @default("[\"leads\",\"contacts\",\"deals\",\"tasks\",\"reports\",\"pipeline\"]")
  dashboardLayout  Json     @default("{}")
  notifications    Json     @default("{\"email\":true,\"push\":true,\"desktop\":true}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ============================================================
// ACCOUNTS (COMPANIES)
// ============================================================

model Account {
  id           String   @id @default(uuid())
  name         String
  domain       String?
  industry     String?
  size         String?  // "1-10", "11-50", "51-200", etc.
  revenue      Float?
  currency     String   @default("INR")
  website      String?
  phone        String?
  address      String?
  city         String?
  state        String?
  country      String?
  linkedin     String?
  description  String?
  tags         Json     @default("[]")
  customFields Json     @default("{}")
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contacts  Contact[]
  deals     Deal[]
  leads     Lead[]

  @@index([name])
  @@index([domain])
  @@index([deletedAt])
}

// ============================================================
// LEADS
// ============================================================

model Lead {
  id              String     @id @default(uuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  company         String?
  jobTitle        String?
  status          LeadStatus @default(NEW)
  source          LeadSource @default(OTHER)
  value           Float?     @default(0)
  currency        String     @default("INR")
  score           Int        @default(0)      // AI/rule-based lead score 0-100
  notes           String?
  tags            Json       @default("[]")
  customFields    Json       @default("{}")
  isDuplicate     Boolean    @default(false)
  duplicateOfId   String?
  convertedAt     DateTime?
  convertedToContactId String?
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  ownerId    String
  owner      User      @relation("LeadOwner", fields: [ownerId], references: [id])
  assigneeId String?
  assignee   User?     @relation("LeadAssignee", fields: [assigneeId], references: [id])
  accountId  String?
  account    Account?  @relation(fields: [accountId], references: [id])

  activities    Communication[]
  tasks         Task[]          @relation("LeadTasks")
  scoreHistory  LeadScoreHistory[]

  @@index([ownerId])
  @@index([assigneeId])
  @@index([status])
  @@index([email])
  @@index([score])
  @@index([createdAt])
  @@index([deletedAt])
}

model LeadScoreHistory {
  id        String   @id @default(uuid())
  score     Int
  reason    String
  createdAt DateTime @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

// ============================================================
// CONTACTS
// ============================================================

model Contact {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  company      String?
  jobTitle     String?
  address      String?
  city         String?
  state        String?
  country      String?
  website      String?
  linkedin     String?
  twitter      String?
  notes        String?
  tags         Json     @default("[]")
  customFields Json     @default("{}")
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])

  deals         Deal[]
  activities    Communication[]
  tasks         Task[]          @relation("ContactTasks")
  tickets       SupportTicket[]
  // Enterprise v2
  preferredLanguage String?     @default("en")
  quotes        Quote[]         @relation("ContactQuotes")

  @@index([ownerId])
  @@index([email])
  @@index([accountId])
  @@index([deletedAt])
}

// ============================================================
// DEALS / OPPORTUNITIES
// ============================================================

model Deal {
  id            String    @id @default(uuid())
  title         String
  value         Float     @default(0)
  currency      String    @default("INR")
  stage         DealStage @default(PROSPECTING)
  probability   Int       @default(10)
  expectedClose DateTime?
  actualClose   DateTime?
  lostReason    String?
  notes         String?
  tags          Json      @default("[]")
  customFields  Json      @default("{}")
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownerId    String
  owner      User     @relation("DealOwner", fields: [ownerId], references: [id])
  assigneeId String?
  assignee   User?    @relation("DealAssignee", fields: [assigneeId], references: [id])
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  accountId  String?
  account    Account? @relation(fields: [accountId], references: [id])

  activities    Communication[]
  tasks         Task[]          @relation("DealTasks")
  documents     Document[]
  invoices      Invoice[]
  stageHistory  DealStageHistory[]
  // Enterprise v2
  stageId         String?
  pipelineStage   PipelineStage?  @relation(fields: [stageId], references: [id])
  stageEnteredAt  DateTime?
  stageTransitions PipelineDealTransition[]
  demoDetail      DemoDetail?
  competitors   Competitor[]    @relation("DealCompetitors")
  quotes        Quote[]         @relation("DealQuotes")
  purchaseOrders PurchaseOrder[] @relation("DealPOs")

  @@index([ownerId])
  @@index([assigneeId])
  @@index([stage])
  @@index([contactId])
  @@index([expectedClose])
  @@index([createdAt])
  @@index([deletedAt])
}

model DealStageHistory {
  id         String    @id @default(uuid())
  fromStage  DealStage?
  toStage    DealStage
  changedAt  DateTime  @default(now())
  changedById String?

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

// ============================================================
// TASKS & ACTIVITIES
// ============================================================

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?
  completedAt DateTime?
  reminderAt  DateTime?
  tags        Json         @default("[]")
  customFields Json        @default("{}")
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Polymorphic relations
  leadId    String?
  lead      Lead?    @relation("LeadTasks", fields: [leadId], references: [id])
  contactId String?
  contact   Contact? @relation("ContactTasks", fields: [contactId], references: [id])
  dealId    String?
  deal      Deal?    @relation("DealTasks", fields: [dealId], references: [id])

  ownerId    String
  owner      User   @relation("TaskOwner", fields: [ownerId], references: [id])
  assigneeId String?
  assignee   User?  @relation("TaskAssignee", fields: [assigneeId], references: [id])
  // Enterprise v2
  followUpStatus String?
  completionPct  Int     @default(0)
  subTasks       SubTask[]

  @@index([ownerId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([deletedAt])
}

// ============================================================
// COMMUNICATIONS (CALLS, EMAILS, NOTES, MEETINGS, SMS)
// ============================================================

model Communication {
  id          String               @id @default(uuid())
  channel     CommunicationChannel
  subject     String?
  body        String?
  direction   String               @default("outbound") // inbound | outbound
  status      String               @default("sent")     // sent | delivered | read | failed
  scheduledAt DateTime?
  sentAt      DateTime?
  metadata    Json                 @default("{}")        // email headers, call duration, etc.
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  // Who sent it
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  // What it's about (polymorphic)
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  ticketId  String?
  ticket    SupportTicket? @relation(fields: [ticketId], references: [id])

  // Activity / meeting fields
  activityStatus  String?   // scheduled | completed | cancelled | no_show
  meetingSummary  String?
  nextAction      String?
  duration        Int?      // meeting duration in minutes
  meetingLink     String?

  // Email thread tracking
  threadId        String?
  parentMessageId String?
  externalId      String?  // provider's message ID

  attachments EmailAttachment[]

  @@index([userId])
  @@index([leadId])
  @@index([contactId])
  @@index([dealId])
  @@index([ticketId])
  @@index([threadId])
  @@index([createdAt])
}

model EmailAttachment {
  id              String   @id @default(uuid())
  filename        String
  fileUrl         String
  fileSize        Int
  mimeType        String
  createdAt       DateTime @default(now())

  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  subject     String
  body        String   // HTML with handlebars {{variables}}
  variables   Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// ============================================================
// AUTOMATION ENGINE
// ============================================================

model Workflow {
  id          String            @id @default(uuid())
  name        String
  description String?
  trigger     AutomationTrigger
  conditions  Json              @default("[]") // [{field, operator, value}]
  actions     Json              @default("[]") // [{type, config}]
  isActive    Boolean           @default(true)
  runCount    Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  logs AutomationLog[]

  @@index([trigger])
  @@index([isActive])
}

model AutomationLog {
  id         String   @id @default(uuid())
  status     String   // success | failed | skipped
  input      Json     @default("{}")
  output     Json     @default("{}")
  error      String?
  executedAt DateTime @default(now())

  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  triggeredById String?
  triggeredBy   User?  @relation(fields: [triggeredById], references: [id])

  @@index([workflowId])
  @@index([executedAt])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  link      String?          // frontend route to navigate
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id          String       @id @default(uuid())
  name        String
  type        DocumentType @default(OTHER)
  fileUrl     String
  fileSize    Int
  mimeType    String
  version     Int          @default(1)
  isLatest    Boolean      @default(true)
  description String?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  dealId  String?
  deal    Deal?   @relation(fields: [dealId], references: [id])

  // Parent document for versioning
  parentId  String?
  versions  Document[] @relation("DocumentVersions")
  parent    Document?  @relation("DocumentVersions", fields: [parentId], references: [id])

  @@index([uploadedById])
  @@index([dealId])
  @@index([deletedAt])
}

// ============================================================
// SUPPORT TICKETS
// ============================================================

model SupportTicket {
  id           String         @id @default(uuid())
  subject      String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  tags         Json           @default("[]")
  slaDeadline  DateTime?
  resolvedAt   DateTime?
  closedAt     DateTime?
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  contactId  String?
  contact    Contact?  @relation(fields: [contactId], references: [id])
  assigneeId String?
  assignee   User?     @relation("TicketAssignee", fields: [assigneeId], references: [id])
  reporterId String
  reporter   User      @relation(fields: [reporterId], references: [id])

  communications Communication[]
  statusHistory  TicketStatusHistory[]

  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([contactId])
  @@index([createdAt])
  @@index([deletedAt])
}

model TicketStatusHistory {
  id         String       @id @default(uuid())
  fromStatus TicketStatus?
  toStatus   TicketStatus
  changedAt  DateTime     @default(now())
  changedById String?

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ============================================================
// INVOICES & BILLING
// ============================================================

model Invoice {
  id           String        @id @default(uuid())
  invoiceNumber String       @unique
  status       InvoiceStatus @default(DRAFT)
  currency     String        @default("INR")
  subtotal     Float
  tax          Float         @default(0)
  discount     Float         @default(0)
  total        Float
  dueDate      DateTime?
  paidAt       DateTime?
  notes        String?
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])
  dealId      String?
  deal        Deal?  @relation(fields: [dealId], references: [id])

  lineItems      InvoiceLineItem[]
  payments       Payment[]
  purchaseOrders PurchaseOrder[]  @relation("InvoicePOs")

  @@index([status])
  @@index([createdById])
  @@index([dealId])
  @@index([deletedAt])
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  description String
  quantity    Float
  unitPrice   Float
  total       Float
  createdAt   DateTime @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  currency      String        @default("INR")
  status        PaymentStatus @default(PENDING)
  method        String?       // stripe, cash, bank_transfer
  transactionId String?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status])
}

// ============================================================
// WEBHOOKS & INTEGRATIONS
// ============================================================

model Webhook {
  id         String   @id @default(uuid())
  name       String
  url        String
  secret     String
  events     Json     @default("[]") // ["lead.created", "deal.updated"]
  isActive   Boolean  @default(true)
  failCount  Int      @default(0)
  lastCalledAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  logs WebhookLog[]

  @@index([isActive])
}

model WebhookLog {
  id         String   @id @default(uuid())
  event      String
  payload    Json
  statusCode Int?
  response   String?
  success    Boolean
  sentAt     DateTime @default(now())

  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([sentAt])
}

// ============================================================
// AUDIT & ACTIVITY LOGS
// ============================================================

model ActivityLog {
  id        String   @id @default(uuid())
  action    String   // created | updated | deleted | logged_in | etc.
  entity    String   // lead | deal | contact | etc.
  entityId  String?
  changes   Json     @default("{}")  // {field: {from, to}}
  details   Json     @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}

// ============================================================
// CUSTOM FIELDS DEFINITIONS
// ============================================================

model CustomFieldDefinition {
  id           String   @id @default(uuid())
  entity       String   // "lead" | "contact" | "deal" | "account"
  fieldKey     String
  fieldLabel   String
  fieldType    String   // "text" | "number" | "date" | "select" | "boolean" | "url"
  options      Json     @default("[]") // for select fields
  isRequired   Boolean  @default(false)
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([entity, fieldKey])
  @@index([entity])
}

// ============================================================
// API KEYS (for public integrations)
// ============================================================

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @unique  // store hashed key only
  keyPrefix   String             // first 8 chars for identification
  permissions Json      @default("[]")
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  createdById String

  @@index([keyHash])
  @@index([createdById])
}

// ============================================================
// ENTERPRISE UPGRADE v2 — New Models
// ============================================================

// ── 1. DYNAMIC PIPELINE STAGES ───────────────────────────────

model PipelineStage {
  id                 String   @id @default(uuid())
  name               String
  order              Int
  pipelineType       String   @default("sales")
  color              String   @default("#6366f1")
  isActive           Boolean  @default(true)
  description        String?
  defaultProbability Int      @default(10)
  isWon              Boolean  @default(false)
  isLost             Boolean  @default(false)
  expectedDays       Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  deals           Deal[]
  toTransitions   PipelineDealTransition[] @relation("TransitionToStage")
  fromTransitions PipelineDealTransition[] @relation("TransitionFromStage")

  @@index([pipelineType])
  @@index([order])
}

model PipelineDealTransition {
  id            String    @id @default(uuid())
  enteredAt     DateTime  @default(now())
  exitedAt      DateTime?
  durationHours Float?

  dealId      String
  deal        Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStageId String?
  fromStage   PipelineStage? @relation("TransitionFromStage", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStageId   String
  toStage     PipelineStage  @relation("TransitionToStage", fields: [toStageId], references: [id])
  changedById String?
  changedBy   User?          @relation("UserPipelineTransitions", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([toStageId])
  @@index([enteredAt])
}

// ── 2. DEMO DETAILS (linked to Deal) ─────────────────────────

model DemoDetail {
  id          String    @id @default(uuid())
  demoDate    DateTime?
  meetingLink String?
  demoStatus  String    @default("Scheduled")
  demoSummary String?
  nextAction  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  dealId String @unique
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

// ── 3. COMPANY SETTINGS ───────────────────────────────────────

model CompanySettings {
  id            String   @id @default(uuid())
  companyName   String
  logoUrl       String?
  footerAddress String?
  country       String   @default("IN")
  currency      String   @default("INR")
  taxNumber     String?
  phone         String?
  email         String?
  website       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── 4. PAYMENT TERMS ──────────────────────────────────────────

model PaymentTerm {
  id          String   @id @default(uuid())
  name        String
  description String?
  content     String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotes Quote[]
}

// ── 5. QUOTES ────────────────────────────────────────────────

enum QuoteType {
  SQ
  SO
  SI
  SCR
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

model Quote {
  id            String      @id @default(uuid())
  quoteNumber   String      @unique
  type          QuoteType   @default(SQ)
  status        QuoteStatus @default(DRAFT)
  currency      String      @default("INR")
  subtotal      Float       @default(0)
  tax           Float       @default(0)
  discount      Float       @default(0)
  total         Float       @default(0)
  validUntil    DateTime?
  notes         String?
  termsContent  String?
  pdfUrl        String?
  country       String      @default("IN")
  financialYear String?
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  createdById   String
  createdBy     User         @relation("UserQuotes", fields: [createdById], references: [id])
  contactId     String?
  contact       Contact?     @relation("ContactQuotes", fields: [contactId], references: [id])
  dealId        String?
  deal          Deal?        @relation("DealQuotes", fields: [dealId], references: [id])
  paymentTermId String?
  paymentTerm   PaymentTerm? @relation(fields: [paymentTermId], references: [id])

  lineItems QuoteLineItem[]

  @@index([type])
  @@index([status])
  @@index([createdById])
  @@index([dealId])
  @@index([deletedAt])
}

model QuoteLineItem {
  id          String   @id @default(uuid())
  description String
  quantity    Float
  unitPrice   Float
  discount    Float    @default(0)
  tax         Float    @default(0)
  total       Float
  createdAt   DateTime @default(now())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

// ── 6. PURCHASE ORDERS ────────────────────────────────────────

enum POStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id        String   @id @default(uuid())
  poNumber  String   @unique
  status    POStatus @default(DRAFT)
  currency  String   @default("INR")
  subtotal  Float    @default(0)
  tax       Float    @default(0)
  total     Float    @default(0)
  notes     String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealId      String?
  deal        Deal?    @relation("DealPOs", fields: [dealId], references: [id])
  invoiceId   String?
  invoice     Invoice? @relation("InvoicePOs", fields: [invoiceId], references: [id])
  createdById String
  createdBy   User     @relation("UserPOs", fields: [createdById], references: [id])

  lineItems POLineItem[]

  @@index([status])
  @@index([dealId])
  @@index([deletedAt])
}

model POLineItem {
  id              String        @id @default(uuid())
  description     String
  quantity        Float
  unitPrice       Float
  total           Float
  createdAt       DateTime      @default(now())

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

// ── 7. LANGUAGES ──────────────────────────────────────────────

model Language {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  direction String   @default("ltr")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([code])
}

// ── 8. FESTIVALS ──────────────────────────────────────────────

model Festival {
  id               String    @id @default(uuid())
  name             String
  date             DateTime
  country          String
  isRecurring      Boolean   @default(true)
  sendDaysBefore   Int       @default(0)
  isAutoSend       Boolean   @default(false)
  targetAll        Boolean   @default(true)
  targetTags       Json      @default("[]")
  emoji            String    @default("🎉")

  // Scheduled direct-send fields
  scheduledAt      DateTime? // exact date+time to auto-send
  whatsappMessage  String?   // WhatsApp message body (supports {name}, {festival})
  emailSubject     String?   // email subject
  emailMessage     String?   // email body (HTML or plain)
  isSent           Boolean   @default(false) // true once scheduledAt send is done

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  messages   FestivalMessage[]
  sendLogs   FestivalSendLog[]
  recipients FestivalRecipient[]

  @@index([country])
  @@index([date])
  @@index([scheduledAt])
}

model FestivalRecipient {
  id              String    @id @default(uuid())
  name            String
  phone           String?   // WhatsApp number with country code e.g. +919876543210
  email           String?
  emailStatus     String    @default("pending")    // pending | sent | failed | skipped
  whatsappStatus  String    @default("pending")    // pending | sent | failed | skipped
  emailError      String?
  whatsappError   String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())

  festivalId String
  festival   Festival @relation(fields: [festivalId], references: [id], onDelete: Cascade)

  @@index([festivalId])
}

model FestivalSendLog {
  id          String   @id @default(uuid())
  channel     String
  status      String   @default("sent")   // sent | failed | skipped
  messageBody String
  sentAt      DateTime @default(now())
  year        Int

  festivalId String
  festival   Festival @relation(fields: [festivalId], references: [id], onDelete: Cascade)
  contactId  String

  @@unique([festivalId, contactId, channel, year])
  @@index([festivalId])
  @@index([contactId])
  @@index([sentAt])
}

model FestivalMessage {
  id              String   @id @default(uuid())
  language        String   @default("en")
  messageTemplate String
  channel         String   @default("EMAIL")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  festivalId String
  festival   Festival @relation(fields: [festivalId], references: [id], onDelete: Cascade)

  @@index([festivalId])
}

// Global customer list — shared across all festivals
model FestivalCustomer {
  id        String   @id @default(uuid())
  name      String
  phone     String?   // WhatsApp number e.g. +919876543210
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ── 9. COMPETITORS ────────────────────────────────────────────

model Competitor {
  id         String   @id @default(uuid())
  name       String
  phone      String?
  website    String?
  strengths  String?
  weaknesses String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  dealId String?
  deal   Deal?   @relation("DealCompetitors", fields: [dealId], references: [id])

  @@index([dealId])
}

// ── 10. SUBTASKS ──────────────────────────────────────────────

model SubTask {
  id          String   @id @default(uuid())
  title       String
  isCompleted Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ── PROJECTS ──────────────────────────────────────────────────

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectTaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

model Project {
  id          String          @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus   @default(PLANNING)
  priority    ProjectPriority @default(MEDIUM)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  tags        String[]        @default([])
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdById String
  createdBy   User   @relation("UserProjects", fields: [createdById], references: [id])

  members     ProjectMember[]
  tasks       ProjectTask[]

  @@index([status])
  @@index([createdById])
  @@index([deletedAt])
}

model ProjectMember {
  id        String   @id @default(uuid())
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId    String
  user      User    @relation("UserProjectMembers", fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectTask {
  id          String            @id @default(uuid())
  title       String
  description String?
  status      ProjectTaskStatus @default(TODO)
  priority    ProjectPriority   @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("UserProjectTasks", fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([assigneeId])
}

// ── Country Targets ──────────────────────────────────────────
model CountryTarget {
  id            String   @id @default(cuid())
  country       String   @unique
  countryCode   String?
  region        String?
  targetRevenue Float    @default(0)
  targetDeals   Int      @default(0)
  priority      String   @default("MEDIUM")
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([country])
  @@index([isActive])
}
